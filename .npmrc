# node_modules achatado (não-symlink) — exigido pelo OpenNext/Cloudflare:
# a estrutura symlink padrão do pnpm impede o bundler de resolver o
# middleware-manifest.json, causando 500 em toda rota no Worker
# (cloudflare/workers-sdk#10236, opennextjs-cloudflare#922).
node-linker=hoisted
shamefully-hoist=true
