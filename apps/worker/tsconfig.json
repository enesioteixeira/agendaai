{
  // Herda module/moduleResolution "bundler" da base — o worker roda via `tsx`
  // (esbuild), que resolve imports extensionless e `.js`→`.ts` igual ao
  // bundler. NÃO usar nodenext aqui: forçaria extensão `.js` nos imports dos
  // packages compartilhados, o que quebra o webpack do apps/web (que os
  // consome como TS cru via transpilePackages). Um único regime de resolução
  // no monorepo evita esse conflito.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
