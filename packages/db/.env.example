# Copie para .env e preencha com a connection string do Neon.
# IMPORTANTE: use o host com "-pooler" (pgbouncer do Neon — é o que o adapter-pg
# espera; doc 03). Veja o passo a passo em docs/10-setup-contas.md §A.1.
DATABASE_URL="postgresql://<user>:<password>@ep-xxxxx-xxxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
